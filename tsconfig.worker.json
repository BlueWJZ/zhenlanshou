{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["worker/**/*.ts", "worker/**/*.d.ts", "db/**/*.ts"]
}
